{
  "name": "dku-geoguesser",
  "version": "1.0.0",
  "description": "GeoGuesser game for Duke Kunshan University campus",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --no-warnings=ExperimentalWarning server/server.js",
    "client": "npm --prefix client run dev",
    "seed": "node --no-warnings=ExperimentalWarning server/db/seed.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
